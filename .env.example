# Required
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FINN_SEARCH_URLS=https://www.finn.no/job/search?q=supply%20chain,https://www.finn.no/job/search?q=planning

# Optional
MIN_SCORE=75
REQUEST_DELAY_SECONDS=3
MAX_DETAIL_FETCHES_PER_RUN=20
MAX_NEW_JOBS_PER_RUN=20
DRY_RUN=true
DB_PATH=data/jobs.sqlite
OPENAI_MODEL=gpt-4.1-mini
FINN_MAX_PAGES_PER_SEARCH=3
HTTP_TIMEOUT_SECONDS=20
LOG_LEVEL=INFO
